# Copy this file to .env.uat or .env.prod.
# debug:revenuecat-native loads .env.uat
# sync:revenuecat-native loads .env.prod

# Elasticsearch: choose one mode.
# Cloud mode:
ELASTICSEARCH_CLOUD_ID=
ELASTICSEARCH_API_KEY=

# Or node mode:
# ELASTICSEARCH_HOST=http://127.0.0.1:9200

# System config id used for member_tiers mapping.
MERCHANT_ID=

# Apple App Store Server API.
APPLE_ENV=PRODUCTION
APPLE_KEY_ID=
APPLE_ISSUER_ID=
APPLE_BUNDLE_ID=
APPLE_APPLE_ID=
APPLE_PRIVATE_KEY_PATH=./AuthKey_8S4KJDKL9U.p8
APPLE_ROOT_CERT_PATH=./AppleRootCA-G3.cer
APPLE_ENABLE_ONLINE_CHECKS=false

# Google Play Android Publisher API.
ANDROID_PACKAGE_NAME=com.bessoga.reelike.android
ANDROID_SERVICE_ACCOUNT_PATH=./android_payment_service_account.json
