{
  "name": "migration-member",
  "version": "1.0.0",
  "private": true,
  "description": "One-time member subscription migration scripts",
  "scripts": {
    "sync:revenuecat:uat": "node scripts/sync-revenuecat-native-iap.js --env=uat",
    "sync:revenuecat:prod": "node scripts/sync-revenuecat-native-iap.js --env=prod",
    "test:subscription:uat": "node scripts/validate-migration-subscriptions.js --env=uat",
    "test:subscription:prod": "node scripts/validate-migration-subscriptions.js --env=prod",
    "check:member-types:uat": "node scripts/report-subscription-types.js --env=uat",
    "check:member-types:prod": "node scripts/report-subscription-types.js --env=prod",
    "revert:members:uat": "node scripts/revert-migration-by-tag.js --env=uat",
    "revert:members:prod": "node scripts/revert-migration-by-tag.js --env=prod",
    "check": "for file in helpers/*.js scripts/*.js; do node --check \"$file\"; done"
  },
  "dependencies": {
    "@apple/app-store-server-library": "1.6.0",
    "@elastic/elasticsearch": "^8.17.1",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2"
  }
}
