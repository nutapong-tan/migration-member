{
  "name": "migration-member",
  "version": "1.0.0",
  "private": true,
  "description": "One-time member subscription migration scripts",
  "scripts": {
    "sync:revenuecat:uat": "node scripts/revenuecat-native-iap-migration.js --env=uat",
    "sync:revenuecat:prod": "node scripts/revenuecat-native-iap-migration.js --env=prod",
    "test:subscription:uat": "node scripts/members-migration-subscription.js --env=uat",
    "test:subscription:prod": "node scripts/members-migration-subscription.js --env=prod",
    "report:member-types:uat": "node scripts/member-subscription-type-report.js --env=uat",
    "report:member-types:prod": "node scripts/member-subscription-type-report.js --env=prod",
    "revert:members:uat": "node scripts/revert-members-from-migration-tag.js --env=uat",
    "revert:members:prod": "node scripts/revert-members-from-migration-tag.js --env=prod",
    "check": "for file in scripts/*.js; do node --check \"$file\"; done"
  },
  "dependencies": {
    "@apple/app-store-server-library": "1.6.0",
    "@elastic/elasticsearch": "^8.17.1",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2"
  }
}
